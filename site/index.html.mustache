{{<page}}
    {{$head}}
    <style>
      ul {
          list-style-type: none;
          padding-left: 0;
          margin-block: 0;
      }
      section {
        margin-block: .75rem;
      }
    </style>
    {{/head}}
    {{$body}}
    <h1>hello!</h1>
    <p>
      i&apos;m a canadian software engineer. i like programming, rollerblading,
      bikes, crafts, and <a class="nowrap" href="/interests">other things</a>.
    </p>
    <p><a href="/status"><b>i&apos;m</b>:</a> {{status.current.text}}</p>
    <section>
      <h2>blog</h2>
      <ul>
        {{#blog.top10}}
        <li>{{date}} <a href="{{url}}">{{title}}</a></li>
        {{/blog.top10}}
        <li><a href="/blog" aria-label="more blog posts">...</a></li>
      </ul>
    </section>
    <section>
      <h2>projects</h2>
      <ul>
        <li><a href="https://github.com/petelliott/petix2"><b>petix2</b></a>: my clone of <a href="https://en.wikipedia.org/wiki/Research_Unix">research unix</a>, with virtual memory and a virtual filesystem.</li>
        <li><a href="https://github.com/petelliott/pscheme"><b>pscheme</b></a>: self-hosted r7rs scheme compiler.</li>
        <li><a href="https://github.com/petelliott/pbasic"><b>pbasic</b></a>: a 4k (code, stack and heap) basic for modern amd64 linux.</li>
        <li><a href="https://github.com/petelliott/schingle"><b>schingle</b></a>: a guile web framework/static site generator (used by this site!).</li>
        <li><a href="/projects" aria-label="more projects">...</a></li>
      </ul>
    </section>
    <section>
      <h2>changelog</h2>
      <ul>
        {{#changelog.top10}}
        <li>{{date}} &ndash; {{text}}</li>
        {{/changelog.top10}}
        <li><a href="/changelog" aria-label="full changelog">...</a></li>
      </ul>
    </section>
    {{/body}}
{{/page}}
